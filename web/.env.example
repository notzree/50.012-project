# Turso Database Connection
# If left blank, the app gracefully falls back to a local SQLite 'local.db' file
TURSO_DATABASE_URL="libsql://your-db-name-your-org.turso.io"
TURSO_AUTH_TOKEN="your-turso-auth-token-string"

# Optional Server-Side Default API Keys (if you want the backend proxy to handle keys instead of BYOK)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_API_KEY=""
GROQ_API_KEY=""
